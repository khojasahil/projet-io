;br&gt;account/policy/identifying_number" vertex="1"><mxGeometry height="90" width="220" x="420" y="470" as="geometry" /></mxCell><mxCell id="t7" parent="1" style="html=1;rounded=1;whiteSpace=wrap;overflow=hidden;align=left;verticalAlign=top;fontSize=10;spacingLeft=4;spacingTop=2;fillColor=#e1d5e7;strokeColor=#9673a6;" value="&lt;b&gt;STR_INVOLVEMENT&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;&lt;br&gt;PK involvement_id&lt;br&gt;FK completing_action_id&lt;br&gt;type_code (1|2), ref_id&lt;br&gt;account/policy/identifying_number" vertex="1"><mxGeometry height="90" width="220" x="900" y="540" as="geometry" /></mxCell><mxCell id="t8" parent="1" style="html=1;rounded=1;whiteSpace=wrap;overflow=hidden;align=left;verticalAlign=top;fontSize=10;spacingLeft=4;spacingTop=2;fillColor=#e1d5e7;strokeColor=#9673a6;" value="&lt;b&gt;STR_BENEFICIARY&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;&lt;br&gt;PK beneficiary_id&lt;br&gt;FK completing_action_id&lt;br&gt;type_code (3|4), ref_id&lt;br&gt;client_number, username, email" vertex="1"><mxGeometry height="90" width="220" x="1150" y="540" as="geometry" /></mxCell><mxCell id="t9" parent="1" style="html=1;rounded=1;whiteSpace=wrap;overflow=hidden;align=left;verticalAlign=top;fontSize=10;spacingLeft=4;spacingTop=2;fillColor=#d5f5e3;strokeColor=#27ae60;" value="&lt;b&gt;STR_ACCOUNT&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;&#xA;&lt;br&gt;PK account_id&#xA;&lt;br&gt;action_type, action_id&#xA;&lt;br&gt;fi/branch/number&#xA;&lt;br&gt;type_code (1-5), currency&#xA;&lt;br&gt;date_opened, date_closed" vertex="1"><mxGeometry height="120" width="230" x="570" y="320" as="geometry" /></mxCell><mxCell id="t10" parent="1" style="html=1;rounded=1;whiteSpace=wrap;overflow=hidden;align=left;verticalAlign=top;fontSize=10;spacingLeft=4;spacingTop=2;fillColor=#d5f5e3;strokeColor=#27ae60;" value="&lt;b&gt;STR_ACCOUNT_HOLDER&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;&#xA;&lt;br&gt;PK holder_id, FK account_id&#xA;&lt;br&gt;type_code (1|2), ref_id" vertex="1"><mxGeometry height="90" width="200" x="660" y="490" as="geometry" /></mxCell><mxCell id="t11" parent="1" style="html=1;rounded=1;whiteSpace=wrap;overflow=hidden;align=left;verticalAlign=top;fontSize=10;spacingLeft=4;spacingTop=2;fillColor=#d5f5e3;strokeColor=#27ae60;" value="&lt;b&gt;STR_VC_DATA&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;&lt;br&gt;PK vc_data_id&lt;br&gt;action_type, action_id&lt;br&gt;data_type (TXN_ID|SEND|RECV)&lt;br&gt;value VARCHAR(200)" vertex="1"><mxGeometry height="90" width="200" x="570" y="790" as="geometry" /></mxCell><mxCell id="te1" edge="1" parent="1" source="t1" style="rounded=1;orthogonalLoop=1;fontSize=9;labelBackgroundColor=#FFFFFF;" target="t2" value="1:N min1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="te2" edge="1" parent="1" source="t1" style="rounded=1;orthogonalLoop=1;fontSize=9;labelBackgroundColor=#FFFFFF;" target="t3" value="1:N req[]"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="te3" edge="1" parent="1" source="t2" style="rounded=1;orthogonalLoop=1;fontSize=9;labelBackgroundColor=#FFFFFF;" target="t4" value="req[]"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="te4" edge="1" parent="1" source="t4" style="rounded=1;orthogonalLoop=1;fontSize=9;labelBackgroundColor=#FFFFFF;" target="t5" value="req[]"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="te5" edge="1" parent="1" source="t2" style="rounded=1;orthogonalLoop=1;fontSize=9;labelBackgroundColor=#FFFFFF;" target="t6" value="req[]"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="te6" edge="1" parent="1" source="t2" style="rounded=1;orthogonalLoop=1;fontSize=9;labelBackgroundColor=#FFFFFF;" target="t9" value="0..1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="te7" edge="1" parent="1" source="t2" style="rounded=1;orthogonalLoop=1;fontSize=9;labelBackgroundColor=#FFFFFF;" target="t11" value="req[]"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="te8" edge="1" parent="1" source="t3" style="rounded=1;orthogonalLoop=1;fontSize=9;labelBackgroundColor=#FFFFFF;" target="t7" value="req[]"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="te9" edge="1" parent="1" source="t3" style="rounded=1;orthogonalLoop=1;fontSize=9;labelBackgroundColor=#FFFFFF;" target="t8" value="req[]"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="te10" edge="1" parent="1" source="t3" style="rounded=1;orthogonalLoop=1;fontSize=9;labelBackgroundColor=#FFFFFF;" target="t9" value="0..1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="te11" edge="1" parent="1" source="t3" style="rounded=1;orthogonalLoop=1;fontSize=9;labelBackgroundColor=#FFFFFF;" target="t11" value="req[]"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="te12" edge="1" parent="1" source="t9" style="rounded=1;orthogonalLoop=1;fontSize=9;labelBackgroundColor=#FFFFFF;" target="t10" value="1:N min1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="n30" value="&lt;b&gt;Le flux :&lt;/b&gt;&lt;br&gt;1. L argent ENTRE (Starting Action) : cash, virement, etc.&lt;br&gt;2. L argent SORT (Completing Action) : depot, virement international, etc.&lt;br&gt;Chaque transaction a au moins 1 starting action." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=9;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;spacingRight=6;shadow=1;rounded=1;" vertex="1" parent="1"><mxGeometry x="800" y="40" width="320" height="80" as="geometry"/></mxCell><mxCell id="n31" value="&lt;b&gt;PIEGE : amount = STRING !&lt;/b&gt;&lt;br&gt;Les montants sont du texte (ex: 11000.00), pas des nombres. CANAFE valide avec une regex. Ne jamais utiliser DECIMAL dans le JSON." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=9;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;spacingRight=6;shadow=1;rounded=1;" vertex="1" parent="1"><mxGeometry x="340" y="280" width="250" height="60" as="geometry"/></mxCell><mxCell id="n32" value="&lt;b&gt;STR_CONDUCTOR&lt;/b&gt;&lt;br&gt;La personne qui fait la transaction (en personne ou en ligne). Toujours typeCode 5 ou 6." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=9;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;spacingRight=6;shadow=1;rounded=1;" vertex="1" parent="1"><mxGeometry x="290" y="590" width="230" height="45" as="geometry"/></mxCell><mxCell id="n33" value="&lt;b&gt;STR_ON_BEHALF_OF&lt;/b&gt;&lt;br&gt;Si le conducteur agit pour quelqu un d autre. Ex: un avocat pour son client." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=9;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;spacingRight=6;shadow=1;rounded=1;" vertex="1" parent="1"><mxGeometry x="290" y="740" width="230" height="40" as="geometry"/></mxCell><mxCell id="n34" value="&lt;b&gt;STR_BENEFICIARY&lt;/b&gt;&lt;br&gt;Qui recoit l argent au final. TypeCode 3 ou 4." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=9;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;spacingRight=6;shadow=1;rounded=1;" vertex="1" parent="1"><mxGeometry x="1150" y="700" width="200" height="40" as="geometry"/></mxCell><mxCell id="n35" value="&lt;b&gt;STR_ACCOUNT&lt;/b&gt;&lt;br&gt;Compte bancaire implique. Peut etre cote starting (source) ou completing (destination)." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=9;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;spacingRight=6;shadow=1;rounded=1;" vertex="1" parent="1"><mxGeometry x="570" y="950" width="250" height="40" as="geometry"/></mxCell><mxCell id="n36" value="&lt;b&gt;STR_VC_DATA&lt;/b&gt;&lt;br&gt;Donnees crypto. Vide pour les transactions classiques mais les 3 arrays JSON sont toujours requis (vides = [])." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=9;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;spacingRight=6;shadow=1;rounded=1;" vertex="1" parent="1"><mxGeometry x="830" y="880" width="250" height="50" as="geometry"/></mxCell><mxCell id="n37" value="&lt;b&gt;req[]&lt;/b&gt; sur les fleches = array requis dans le JSON, meme s il est vide. Toujours emettre [] jamais omettre." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=9;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;spacingRight=6;shadow=1;rounded=1;" vertex="1" parent="1"><mxGeometry x="1200" y="280" width="220" height="50" as="geometry"/></mxCell></root></mxGraphModel></diagram></mxfile>