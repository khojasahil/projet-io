<?xml version="1.0" encoding="UTF-8"?><mxfile host="app.diagrams.net"><diagram id="p5" name="5 - Audit"><mxGraphModel dx="1000" dy="800" grid="1" gridSize="10" page="0"><root><mxCell id="0" /><mxCell id="1" parent="0" /><mxCell id="ag1" value="AUDIT ET TRACABILITE" style="html=1;rounded=1;fillColor=#f5f5f5;opacity=15;fontSize=14;fontStyle=1;verticalAlign=top;spacingTop=5;dashed=1;dashPattern=5 5;" vertex="1" parent="1"><mxGeometry x="10" y="10" width="650" height="400" as="geometry" /></mxCell><mxCell id="u1" value="&lt;b&gt;STR_REPORT&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;&lt;br&gt;str_report_id PK" style="html=1;rounded=1;whiteSpace=wrap;overflow=hidden;align=left;verticalAlign=top;fontSize=10;spacingLeft=4;spacingTop=2;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="30" y="50" width="150" height="35" as="geometry" /></mxCell><mxCell id="u2" value="&lt;b&gt;STR_API_SUBMISSION&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;&lt;br&gt;PK submission_id&lt;br&gt;FK str_report_id&lt;br&gt;submitted_at, http_status_code&lt;br&gt;canafe_acknowledgement_id&lt;br&gt;success_indicator BOOLEAN" style="html=1;rounded=1;whiteSpace=wrap;overflow=hidden;align=left;verticalAlign=top;fontSize=10;spacingLeft=4;spacingTop=2;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="250" y="40" width="260" height="120" as="geometry" /></mxCell><mxCell id="u3" value="&lt;b&gt;STR_SUBMITTED_PAYLOAD&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;&lt;br&gt;PK payload_id&lt;br&gt;FK submission_id&lt;br&gt;payload_json TEXT&lt;br&gt;payload_hash_sha256 VARCHAR(64)" style="html=1;rounded=1;whiteSpace=wrap;overflow=hidden;align=left;verticalAlign=top;fontSize=10;spacingLeft=4;spacingTop=2;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="250" y="190" width="260" height="90" as="geometry" /></mxCell><mxCell id="u4" value="&lt;b&gt;STR_VALIDATION_ERROR&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;&lt;br&gt;PK error_id&lt;br&gt;FK str_report_id&lt;br&gt;instance_path, keyword&lt;br&gt;message_en/fr TEXT" style="html=1;rounded=1;whiteSpace=wrap;overflow=hidden;align=left;verticalAlign=top;fontSize=10;spacingLeft=4;spacingTop=2;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="30" y="140" width="200" height="90" as="geometry" /></mxCell><mxCell id="u5" value="&lt;b&gt;STR_AUDIT_EVENT&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;&lt;br&gt;PK event_id&lt;br&gt;FK str_report_id&lt;br&gt;event_type, event_user&lt;br&gt;event_timestamp, event_details" style="html=1;rounded=1;whiteSpace=wrap;overflow=hidden;align=left;verticalAlign=top;fontSize=10;spacingLeft=4;spacingTop=2;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="30" y="270" width="200" height="90" as="geometry" /></mxCell><mxCell id="ue1" value="1:N" style="rounded=1;orthogonalLoop=1;fontSize=9;labelBackgroundColor=#FFFFFF;" edge="1" source="u1" target="u2" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="ue2" value="1:1" style="rounded=1;orthogonalLoop=1;fontSize=9;labelBackgroundColor=#FFFFFF;" edge="1" source="u2" target="u3" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="ue3" value="1:N" style="rounded=1;orthogonalLoop=1;fontSize=9;labelBackgroundColor=#FFFFFF;" edge="1" source="u1" target="u4" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="ue4" value="1:N" style="rounded=1;orthogonalLoop=1;fontSize=9;labelBackgroundColor=#FFFFFF;" edge="1" source="u1" target="u5" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="n40" value="&lt;b&gt;Pourquoi l audit ?&lt;/b&gt;&lt;br&gt;CANAFE peut auditer votre banque. Vous devez prouver :&lt;br&gt;- Ce que vous avez envoye (copie JSON)&lt;br&gt;- Quand vous l avez envoye&lt;br&gt;- Que personne ne l a modifie (hash SHA-256)&lt;br&gt;- Les erreurs rencontrees&lt;br&gt;&lt;br&gt;Conservation : minimum 5 ans." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=9;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;spacingRight=6;shadow=1;rounded=1;" vertex="1" parent="1"><mxGeometry x="30" y="450" width="300" height="110" as="geometry"/></mxCell><mxCell id="n41" value="&lt;b&gt;STR_API_SUBMISSION&lt;/b&gt;&lt;br&gt;Le recu : quand on a envoye, code HTTP (200=OK, 400=erreur), ID accuse de reception CANAFE." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=9;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;spacingRight=6;shadow=1;rounded=1;" vertex="1" parent="1"><mxGeometry x="530" y="40" width="250" height="50" as="geometry"/></mxCell><mxCell id="n42" value="&lt;b&gt;STR_SUBMITTED_PAYLOAD&lt;/b&gt;&lt;br&gt;Copie exacte du JSON envoye + empreinte SHA-256. Preuve d integrite." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=9;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;spacingRight=6;shadow=1;rounded=1;" vertex="1" parent="1"><mxGeometry x="530" y="190" width="250" height="40" as="geometry"/></mxCell><mxCell id="n43" value="&lt;b&gt;STR_VALIDATION_ERROR&lt;/b&gt;&lt;br&gt;Erreurs CANAFE. Le champ instance_path dit exactement ou est l erreur dans le JSON." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=9;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;spacingRight=6;shadow=1;rounded=1;" vertex="1" parent="1"><mxGeometry x="250" y="140" width="250" height="45" as="geometry"/></mxCell><mxCell id="n44" value="&lt;b&gt;STR_AUDIT_EVENT&lt;/b&gt;&lt;br&gt;Journal de bord : qui a cree, modifie, valide et soumis le rapport. Trace complete." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=9;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;spacingRight=6;shadow=1;rounded=1;" vertex="1" parent="1"><mxGeometry x="250" y="310" width="250" height="40" as="geometry"/></mxCell></root></mxGraphModel></diagram></mxfile>